;; fleet.edn — the kotoba WASM mesh fleet inventory (SSoT).
;;
;; murakumo operates these nodes over Tailscale SSH. Each `:host` is a Tailscale
;; MagicDNS name (or IP) reachable as `ssh <host>`. `:roles` map to kotoba's
;; KOTOBA_NODE_ROLES; `:labels` to KOTOBA_NODE_LABELS (placement constraints the
;; lattice auction matches). `:port` is the node's kotoba-server HTTP port.
;;
;; The names mirror the etzhayyim murakumo cell fleet (12 tribes), but THIS fleet
;; is the kotoba mesh layer (libp2p lattice hosting WASM components), distinct
;; from the k3s/Ansible LangGraph-cell control plane (etzhayyim-project-murakumo).
{:fleet/name "com-junkawasaki-kotoba-mesh"
 :fleet/port 8077                      ; default kotoba-server HTTP port per node
 :fleet/p2p-port 4001                  ; default libp2p QUIC port (fixed → predictable multiaddr)
 :fleet/operator-seed-env "MURAKUMO_OPERATOR_SEED"  ; 32-byte hex; shared operator DID across the fleet

 :nodes
 [{:name "naphtali" :host "naphtali" :rpc-ip "192.168.1.25" :mac "1c:f6:4c:35:21:a5" :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  ;; simeon is the ipfs-pinner — its IPFS daemon owns UDP 4001, so give the mesh
  ;; node a different libp2p port (4001 default would fail swarm init).
  {:name "simeon"   :host "simeon@simeon" :rpc-ip "192.168.1.24" :mac "1c:f6:4c:51:5e:ec" :p2p-port 4003 :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  {:name "judah"    :host "judah"    :rpc-ip "192.168.1.21" :mac "1c:f6:4c:56:a9:52" :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  {:name "zebulun"  :host "zebulun"  :rpc-ip "192.168.1.19" :mac "1c:f6:4c:57:c8:4d" :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  {:name "levi"     :host "levi@levi" :rpc-ip "192.168.1.26" :mac "1c:f6:4c:62:84:7d" :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  {:name "joseph"   :host "joseph@joseph" :rpc-ip "192.168.1.17" :mac "1c:f6:4c:4e:b9:2b" :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  ;; issachar already runs a kotoba-server on :8077 (yabai CTI persistence) — give
  ;; the murakumo mesh node its own ports so the two coexist.
  {:name "issachar" :host "issachar" :rpc-ip "192.168.1.23" :mac "1c:f6:4c:55:db:4b" :port 8076 :p2p-port 4002 :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  {:name "dan"      :host "dan@dan"  :rpc-ip "192.168.1.18" :mac "1c:f6:4c:5a:34:d9" :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp" :role "pdshost"}}
  {:name "benjamin" :host "benjamin" :rpc-ip "192.168.1.20" :mac "1c:f6:4c:53:5b:d4" :roles ["pin" "compute"] :labels {:tier "edge" :zone "jp"}}
  ;; asher = replica/failover; also the canary (verified reachable first).
  {:name "asher"    :host "asher"    :rpc-ip "192.168.1.22" :mac "1c:f6:4c:4f:46:5c" :roles ["pin" "compute" "relay"] :labels {:tier "edge" :zone "jp" :role "canary"}}
  ;; gad — Linux/ROCm GPU box, NOT a 12-tribes Mac mini and not a kotoba P2P
  ;; mesh member (no :pin role, doesn't run kotoba-server). Compute-only:
  ;; murakumo.infer.media's ComfyUI render farm (animagine-xl-4.0 resident),
  ;; ~9x faster per image than the MPS-backed mesh nodes above (dedicated
  ;; discrete GPU + unified-memory-free VRAM vs Mac mini shared memory —
  ;; verified 2026-07-13, ai-gftd-mangaka session). Reachable as `ssh gad`
  ;; (Tailscale, ~/.ssh/config alias → 100.82.98.110).
  {:name "gad" :host "gad" :roles ["compute"] :labels {:tier "gpu" :zone "jp" :role "comfy-render"}}
  ;; xavier — NVIDIA Jetson AGX Xavier devkit (32GB LPDDR4x, 512-core Volta
  ;; GPU, 8-core Carmel), NOT a 12-tribes Mac mini and not a kotoba P2P mesh
  ;; member (no :pin role, doesn't run kotoba-server). Physically on gad's
  ;; wired LAN (192.168.1.28). Recovered 2026-07-15 via full JetPack 5.1.x
  ;; (L4T R35.4.1, Ubuntu 20.04) reflash after a forgotten OS password —
  ;; flashed from gad (an x86_64 host) since this fleet's Macs are Apple
  ;; Silicon and can't run NVIDIA's x86_64-only flash tooling. Second
  ;; independent standalone-serving inference head (NOT part of gad's RPC
  ;; ring), llama.cpp built from source with CUDA (JetPack 5.1.x / CUDA
  ;; 11.4, sm72 — no official Jetson+CUDA release binary exists upstream),
  ;; models on the 466GB NVMe (/mnt/nvme), served via
  ;; murakumo-standalone-cuda.service on :8090.
  ;;
  ;; 2026-07-18: **switched from qwen3.6-35b-a3b-xavier-cuda to
  ;; qwen3-vl-30b-a3b-xavier-cuda** (owner directive — "xavier を vl に置き換
  ;; える" — vision-quality upgrade). Same manga-character-identification
  ;; benchmark this ADR's fleet-main pick (qwen3.6) scored :measurement
  ;; accuracy=0.283 (worst of the fleet-OSS set) on: qwen3-vl-30b-a3b
  ;; reproduces the gad result exactly (accuracy=0.833, 3/3 stable runs,
  ;; identical panel-by-panel output) — GGUF quantization is deterministic
  ;; across hosts, only throughput differs. Verified end-to-end on xavier
  ;; itself before the systemd cutover: download (18.5GB GGUF Q4_K_M +
  ;; 1.1GB mmproj F16) → manual llama-server smoke test (vision OK, one
  ;; live manga-page request: 2314 prompt / 74 completion tokens in 66.4s)
  ;; → 3x identification benchmark via SSH port-forward from the fleet
  ;; client, matching gad bit-for-bit → THEN cut over the systemd unit
  ;; (`-c 8192`, not the old unit's `-c 262144` — that ceiling was sized for
  ;; qwen3.6's 262144-token native context and is unnecessary headroom this
  ;; model doesn't need on 30GB RAM; `--reasoning off` required or answers
  ;; land in reasoning_content with empty content, same footgun measured on
  ;; gad). systemd load: ~103s cold model+mmproj load, ~6.9GB resident.
  ;; qwen3.6-35b-a3b weights (+mmproj) kept on /mnt/nvme for rollback (ample
  ;; disk: 387GB free after both models resident) — same policy as gad's
  ;; retained-gemma4 precedent; restore by reverting the unit's ExecStart.
  ;; Old speed baseline (gad 31.5 tok/s prefill / 30.9 tok/s decode vs
  ;; Xavier 5.0 / 11.5 — Xavier ~6x/2.7x slower, 2018 Volta + lower LPDDR4x
  ;; bandwidth, MoE decode is memory-bandwidth bound) is architecture-level
  ;; and carries over; not independently re-benchmarked for qwen3-vl (same
  ;; A3B active-param class, expect a similar ratio — flagged as unverified
  ;; here, do not treat as measured).
  ;;
  ;; Registered in api.murakumo.cloud as node `head-xavier` / model
  ;; `qwen3-vl-30b-a3b-xavier-cuda`, endpoint is Tailscale-only (no public
  ;; Cloudflare Tunnel route set up yet). Reachable as `ssh xavier`
  ;; (Tailscale → 100.87.226.80). NOTE (2026-07-17/18): this host has no
  ;; entry in ~/.ssh/config (unlike gad) and MagicDNS hostname resolution
  ;; (`xavier.tail110d8b.ts.net`) was observed unreachable from at least one
  ;; client Mac even with `tailscale status` showing the peer online and
  ;; `tailscale dns query` resolving it correctly server-side — use
  ;; `ssh -o "ProxyCommand=tailscale nc %h %p" xavier@xavier.tail110d8b.ts.net`
  ;; (or the raw Tailscale IP with the same ProxyCommand) as a working
  ;; fallback when `ssh xavier` / `tailscale ssh xavier` fail to resolve.
  {:name "xavier" :host "xavier" :rpc-ip "192.168.1.28" :mac "48:b0:2d:18:4d:16" :roles ["compute"] :labels {:tier "gpu" :zone "jp" :role "cuda-infer"}}]}
