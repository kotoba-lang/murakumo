;; infer.edn — murakumo distributed-inference config (SSoT for `bb murakumo infer`).
;;
;; The mesh fleet (fleet.edn) is reused as the inference fleet; :extra-nodes adds
;; machines that serve inference but are not kotoba-mesh members. The HEAD is the
;; operator's own machine: it holds the checkpoint on disk, drives the ring, and
;; serves the OpenAI-compatible API.
{:infer/rpc-port 50052
 :infer/api-port 8090
 ;; Claude Code (via the /v1/messages Anthropic bridge) always sends its full
 ;; ~89-tool definition set — ~48K prompt tokens before the conversation even
 ;; starts. 4096 (llama-server's own default) and then 65536 both proved too
 ;; tight in real use (2026-07-05: a real request hit 65561, 25 over 65536).
 ;; 262144 is qwen-agentworld-35b-a3b's own native training context (the GGUF
 ;; metadata's qwen35moe.context_length) — the real ceiling on THIS binary,
 ;; not an arbitrary round number: llama-server hard-caps any -c above this
 ;; to 262144 regardless of --rope-scaling yarn overrides (a known upstream
 ;; bug, ggml-org/llama.cpp#22140 closed-not-planned, #17459 open-unconfirmed
 ;; — the model's own YaRN-extended 1,010,000 claim needs a source patch +
 ;; rebuild to actually reach, not a config flag). KV cache at 262144 (only
 ;; 10/40 layers are full-attention — full_attention_interval=4 hybrid
 ;; Gated-DeltaNet/SSM architecture, the other 30 use a FIXED ~63MB recurrent
 ;; state regardless of context length) measures 5GB f16 — trivial against
 ;; the head's ~46GB unified RAM alongside the 20.6GB model.
 :infer/ctx 262144
 ;; auto-detect measured no different from explicit 'on' for this model (RADV
 ;; Vulkan backend, mostly-linear-attention arch limits how much FA can help)
 ;; — set explicitly so it's not silently 'auto'-disabled by a future build.
 :infer/flash-attn "on"
 ;; GPU-wired ceiling provisioned onto each 16 GiB worker (sudo sysctl
 ;; iogpu.wired_limit_mb) — 13 GiB wired leaves ~3 GiB for macOS + the mesh node.
 :infer/wired-limit-mb 13312
 ;; Workers are headless: macOS floor ≈ 2.5 GiB once we stop counting desktop apps.
 :infer/node-os-reserve-gib 2
 :infer/node-headroom-gib 5/4
 :infer/head-headroom-gib 5/4
 ;; The head holds the GGUF, drives the ring, serves /v1. When the operator\'s
 ;; machine is NOT on the fleet LAN (probe it: >5 ms RTT to workers ⇒ every
 ;; token pays it), promote a fleet node instead: :remote? true + :host, and
 ;; a modest os-reserve since it also mmaps the checkpoint while serving.
 :infer/head {:name "head" :host "root@100.82.98.110" :remote? true
              :os-reserve-gib 5
              :bin-dir "/home/gad/murakumo/llama.cpp/build-rpc-glm/bin"
              :model-dir "/home/gad/models/GLM-5.2-REAP50-Q2_K-GGUF"
              ;; GPU-backend build for `infer serve-standalone` (no RPC ring).
              ;; CPU-only :bin-dir above never engaged the head's Radeon 8060S
              ;; iGPU even at -ngl 999 — see cmd-serve-standalone docstring.
              :standalone-bin-dir "/home/gad/murakumo/llama.cpp/build-vulkan/llama-b9873"}
 :infer/extra-nodes []
 ;; rpc-server -c caches streamed shards on the worker's disk; skip when free
 ;; disk < this (the cache costs ~one shard).
 :infer/cache-min-free-gib 20
 ;; mlx-moe defaults are intentionally sparse; model entries can pin capacity,
 ;; pin-top-k, warmup, profile, or extra args when a measured profile exists.
 :infer/mlx-moe {:kv-bits 8 :warmup "none"}

 :models
 {;; ── base text models (2026-07-04): glm-5.2-reap50-q2k doesn't fit the fleet
  ;; reliably right now (139GB, ~all of :total-usable-bytes) — these three are
  ;; the new default `bb murakumo infer plan/provision/up` base text targets,
  ;; small enough to fit a handful of edge nodes or the single GPU head alone.
  "qwen-agentworld-35b-a3b"
  {:model/id "qwen-agentworld-35b-a3b"
   :model/family "Qwen-AgentWorld"
   :model/format :gguf
   :hf/repo "unsloth/Qwen-AgentWorld-35B-A3B-GGUF"
   :model/params-b 35 :model/active-params-b 3
   :model/layers 40
   :model/experts 256
   :model/active-experts 9            ; 8 routed + 1 shared
   :model/moe-shared-expert? true
   :model/context 262144
   :model/gguf "Qwen-AgentWorld-35B-A3B-UD-Q4_K_M.gguf"
   ;; HF file-listing size (UD-Q4_K_M, 2026-07-04) — not yet probed on-disk,
   ;; unlike the byte-exact entries below.
   :model/weight-bytes 22100000000}

  "qwen3.6-35b-a3b"
  {:model/id "qwen3.6-35b-a3b"
   :model/family "Qwen3.6"
   :model/format :gguf
   :hf/repo "lmstudio-community/Qwen3.6-35B-A3B-GGUF"
   :model/params-b 35 :model/active-params-b 3
   :model/layers 40
   :model/experts 256
   :model/active-experts 9            ; 8 routed + 1 shared
   :model/moe-shared-expert? true
   :model/context 262144              ; extensible to 1,010,000 via YaRN
   :model/gguf "Qwen3.6-35B-A3B-Q4_K_M.gguf"
   :model/weight-bytes 21200000000}   ; HF file-listing size, not yet probed on-disk

  "gemma-4-12b-it"
  {:model/id "gemma-4-12b-it"
   :model/family "Gemma 4"
   :model/format :gguf
   :hf/repo "unsloth/gemma-4-12b-it-GGUF"
   :model/params-b 12                 ; dense (11.95B), not MoE
   :model/layers 48
   :model/context 262144
   :model/gguf "gemma-4-12b-it-Q4_K_M.gguf"
   :model/weight-bytes 7120000000}    ; HF file-listing size, not yet probed on-disk

  "glm-5.2-reap50-q2k"
  {:model/id "glm-5.2-reap50-q2k"
   :model/family "GLM-5.2"
   :model/format :gguf
   :hf/repo "pipenetwork/GLM-5.2-REAP50-Q2_K-GGUF"
   :model/params-b 381            ; REAP50: 128 of 256 experts kept per layer
   :model/active-params-b 39
   :model/layers 78               ; zai-org/GLM-5.2 num_hidden_layers
   :model/dense-layers 3          ; first_k_dense_replace: light, expert-free layers
   :model/dense-layer-frac 1/10
   :model/weight-bytes 139000000000
   :model/gguf "GLM-5.2-REAP50-Q2_K-00001-of-00004.gguf"
   :model/llama-extra-args ["--temp" "0.6" "--repeat-penalty" "1.1" "--top-p" "0.95"]}

  "gemma-4-26b-a4b"
  {:model/id "gemma-4-26b-a4b"
   :model/family "Gemma 4"
   :model/format :gguf
   :hf/repo "unsloth/gemma-4-26B-A4B-it-GGUF"
   :model/gguf "gemma-4-26B-A4B-it-MXFP4_MOE.gguf"
   :model/params-b 26 :model/active-params-b 4
   :model/layers 48
   :model/weight-bytes 16551046944
   ;; 実測 2026-07-02: 3×M4 mini (Metal RPC) + gad head, 全LAN:
   ;; prefill 18.3 / decode 13.88 tok/s
   :model/experts 128}

  "nemotron-3-nano-30b-a3b"
  {:model/id "nemotron-3-nano-30b-a3b"
   :model/family "Nemotron 3 Nano"
   :model/format :gguf
   :hf/repo "unsloth/Nemotron-3-Nano-30B-A3B-GGUF"
   :model/gguf "Nemotron-3-Nano-30B-A3B-Q4_K_M.gguf"
   :model/params-b 30 :model/active-params-b 3
   :model/layers 52
   :model/weight-bytes 24574373664
   ;; ⚠ RPC 分散不可 (実測 2026-07-02): Mamba-2 hybrid の再帰状態が
   ;; ggml RPC backend でグラフ構築できない ([create_node] invalid data ptr、
   ;; llama.cpp #20570 系)。単一ノード実行のみ。
   :model/rpc-capable? false}

  "qwen3-next-80b-a3b"
  {:model/id "qwen3-next-80b-a3b"
   :model/family "Qwen3-Next"
   :model/format :gguf
   :hf/repo "Qwen/Qwen3-Next-80B-A3B-Instruct-GGUF"
   :model/gguf "Qwen3-Next-80B-A3B-Instruct-Q4_K_M.gguf"
   :model/params-b 80 :model/active-params-b 3
   :model/layers 48
   :model/weight-bytes 48410988384
   ;; 実測 2026-07-02: 6×M4 mini (-ngl 38 ≈6.4GB/台) + gad CPU 10 層, 全LAN:
   ;; prefill 6.1 / decode 4.68 tok/s。-ngl 44+ は linear-attention の
   ;; compute buffer で 16GB Mac が Metal OOM。
   :model/experts 512}

  ;; ── media (Civitai/HF 系。ジョブ並列 = 1 ノード完結、sharding 不要) ──
  "animagine-xl-4.0"
  {:model/id "animagine-xl-4.0"
   :model/kind :image
   :model/family "SDXL"
   :hf/repo "cagliostrolab/animagine-xl-4.0"
   :model/checkpoint "animagine-xl-4.0.safetensors"
   :model/engine :comfyui
   :credit/per-image 100}

  ;; Requested source huggingface.co/John6666/wai-nsfw-illustrious-sdxl-v150-sdxl
  ;; ships diffusers-format only (unet/vae/text_encoder subfolders, no root
  ;; single-file .safetensors), which CheckpointLoaderSimple can't load — so
  ;; the checkpoint actually deployed is the same v15.0 weights' single-file
  ;; upload from the model's Civitai origin (WAI0731/WAI-illustrious-SDXL,
  ;; civitai.com/models/827184, modelVersionId 2167369).
  "wai-illustrious-sdxl-v150"
  {:model/id "wai-illustrious-sdxl-v150"
   :model/kind :image
   :model/family "SDXL"
   :hf/repo "John6666/wai-nsfw-illustrious-sdxl-v150-sdxl"
   :civitai/model-id 827184
   :civitai/model-version-id 2167369
   :model/checkpoint "waiIllustriousSDXL_v150.safetensors"
   :model/engine :comfyui
   :credit/per-image 100}

  "ltxv-2b-0.9.1"
  {:model/id "ltxv-2b-0.9.1"
   :model/kind :ltx-video
   :model/family "LTX-Video 2B (DiT)"
   :hf/repo "Lightricks/LTX-Video"
   :model/checkpoint "ltx-video-2b-v0.9.1.safetensors"
   :model/engine :comfyui
   :model/min-free-bytes 5368709120    ; 5.72GB DiT; ComfyUI mmaps, ~6GB peak on 16GB
   :credit/per-video-second 30}

  "svd-xt"
  {:model/id "svd-xt"
   :model/kind :video
   :model/family "Stable Video Diffusion XT"
   :hf/repo "stabilityai/stable-video-diffusion-img2vid-xt"
   :model/checkpoint "svd_xt.safetensors"
   :model/engine :comfyui
   :model/min-free-bytes 5368709120    ; ComfyUI mmaps into unified memory; 5 GiB headroom
   :credit/per-video-second 40}

  "stable-audio-open"
  {:model/id "stable-audio-open"
   :model/kind :audio
   :model/family "Stable Audio Open"
   :hf/repo "stabilityai/stable-audio-open-1.0"
   :model/checkpoint "stable-audio-open-1.0.safetensors"
   :model/engine :comfyui
   :model/min-free-bytes 6442450944
   :credit/per-audio-second 8}

  "glm-5.2-reap50-4bit-mlx"
  {:model/id "glm-5.2-reap50-4bit-mlx"
   :model/family "GLM-5.2"
   :model/format :mlx
   :hf/repo "pipenetwork/GLM-5.2-REAP50-MLX-4bit"
   :model/params-b 381
   :model/active-params-b 39
   :model/layers 78
   :model/dense-layers 3
   :model/dense-layer-frac 1/10
   :model/weight-bytes 229780000000} ; 214 GiB — needs ~19 more 16 GiB nodes

  "glm-5.2-mxfp4-mlx-moe"
  {:model/id "glm-5.2-mxfp4-mlx-moe"
   :model/family "GLM-5.2"
   :model/format :mlx
   :model/engine :mlx-moe
   :model/mlx-repo "mlx-community/GLM-5.2-mxfp4"
   :model/params-b 744
   :model/active-params-b 40
   :model/layers 78
   :model/dense-layers 3
   :model/dense-layer-frac 1/10
   :model/experts 256
   :model/active-experts 8
   :model/moe-shared-expert? true
   ;; Local measurement on 32 GiB Apple Silicon with the Clojure/Datomic profile:
   ;; capacity=4 is stable but low quality; capacity=8 loads around 22 GiB wired
   ;; and is the first useful hot-expert cache setting. 16 GiB M4 minis remain
   ;; below this tier, so GLM-5.2 fleet quality should use the GGUF/RPC path.
   :model/mlx-moe-capacity-tiers [[24 8] [20 4]]
   :model/capacity 8
   :model/pin-top-k 8
   :model/kv-bits 8
   :model/warmup "none"
   :model/mlx-moe-profile "$HOME/.cache/mlx-moe/glm-5.2-mxfp4-clj-datomic-profile.json"
   :model/weight-bytes 395110000000} ; HF download size, rounded decimal bytes

  ;; ── mlx-moe (single-node, SSD-paged experts — mu-hashmi/mlx-moe) ──────────
  ;; :model/engine :mlx-moe routes `infer plan`/`provision`/`serve` to
  ;; murakumo.infer.moe instead of the fleet-wide ring: ONE node with ≥32 GiB
  ;; usable memory serves the whole checkpoint, inactive experts stream from
  ;; its own SSD. Numbers below are the mlx-moe README's OWN measured table
  ;; for this exact checkpoint, not derived from a GGUF/MLX file we've probed
  ;; (:model/weight-bytes is therefore the README's rounded "46 GB", not a
  ;; byte-exact file size like the other entries).
  "qwen3-coder-next-mlx-moe"
  {:model/id "qwen3-coder-next-mlx-moe"
   :model/family "Qwen3-Coder-Next"
   :model/format :mlx
   :model/engine :mlx-moe
   :model/mlx-repo "mlx-community/Qwen3-Coder-Next-4bit"
   :model/layers 48                     ; MoE layers (README)
   :model/experts 512
   :model/active-experts 10             ; top-k
   :model/moe-shared-expert? true
   :model/weight-bytes 46000000000}}}   ; ~46 GB full 4-bit checkpoint (OOMs a 32 GiB Mac whole)
