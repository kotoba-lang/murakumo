{;; murakumo — kotoba WASM mesh control plane (babashka; uses built-in
 ;; babashka.process + cheshire). The only external dep is the zero-dep,
 ;; pure-.cljc kotoba-fleet lib, for the `fleet` coordination-view command.
 :paths ["src"]
 :deps {io.github.kotoba-lang/kotoba-fleet {:local/root "../kotoba-fleet"}}
 :tasks
 {murakumo
  {:doc "kotoba WASM mesh control plane. `bb murakumo` for the command list. Drives the Tailscale fleet over SSH: provision/up/down/status/deploy."
   :requires ([murakumo.core :as core])
   :task (apply core/-main *command-line-args*)}

  nodes    {:doc "Fleet reachability + mesh presence."           :requires ([murakumo.core :as core]) :task (apply core/-main "nodes" *command-line-args*)}
  status   {:doc "Fold /health + lattice ps across the fleet."   :requires ([murakumo.core :as core]) :task (apply core/-main "status" *command-line-args*)}
  provision{:doc "rsync binaries + install resident LaunchDaemon."  :requires ([murakumo.core :as core]) :task (apply core/-main "provision" *command-line-args*)}
  mesh     {:doc "Form ONE gossipsub lattice across the fleet (peer-id + bootstrap)." :requires ([murakumo.core :as core]) :task (apply core/-main "mesh" *command-line-args*)}
  dash     {:doc "Web dashboard + snapshotter: persists fleet heartbeat/placement to the Datom log and serves `status` as a web page. Args: [port=8899] [interval-s=15]." :requires ([murakumo.dash :as dash]) :task (apply dash/-main *command-line-args*)}
  deploy   {:doc "Compile clj→WASM + publish to a node's lattice." :requires ([murakumo.core :as core]) :task (apply core/-main "deploy" *command-line-args*)}
  reconcile{:doc "Declarative desired-state (wadm): fold murakumo.app.edn vs live placement. Flags: --dry-run|--apply|--watch[=secs]." :requires ([murakumo.core :as core]) :task (apply core/-main "reconcile" *command-line-args*)}
  fleet    {:doc "Coordination view: fold a kotoba-fleet Datom log into one snapshot (holders · leases · pending). Args: <datom-log.edn> [now-ms]." :requires ([murakumo.core :as core]) :task (apply core/-main "fleet" *command-line-args*)}
  cloud    {:doc "Plan murakumo.cloud overlay records/routes/connect/relay/bootstrap argv. Args: [plan|records|routes|dial|connect <node>|relay <name>|bootstrap] [--cloud=cloud.edn] [--fleet=fleet.edn]." :requires ([murakumo.cloud :as cloud]) :task (apply cloud/-main *command-line-args*)}
  overlay  {:doc "Native murakumo overlay driver shell. Args: adapters | dial-check|relay-check|serve-relay|local-forward|local-forward-bytes --overlay ... | dial|relay --overlay ... | bootstrap|run|dispatch|execute --manifest-file bootstrap.edn." :requires ([murakumo.overlay :as overlay]) :task (apply overlay/-main *command-line-args*)}
  overlay-adapter {:doc "Reference external transport adapter. Args: check|dial|serve|serve-once --request-edn '<adapter-request>'." :requires ([murakumo.overlay.adapter :as adapter]) :task (apply adapter/-main *command-line-args*)}
  quic-cert {:doc "Issue/ensure stored QUIC cert/key material under .murakumo/kagi/quic." :task (apply shell "clojure" "-M:quic-cert" *command-line-args*)}
  quic-driver {:doc "JVM Clojure QUIC transport driver. Args: check|dial|serve|serve-once --request-edn '<adapter-request>'." :task (apply shell "clojure" "-M:quic-driver" *command-line-args*)}
  infer    {:doc "Distributed inference (exo-style memory-weighted shard plan): probe|plan|provision|up|down|ps|serve|generate." :requires ([murakumo.core :as core]) :task (apply core/-main "infer" *command-line-args*)}

  test     {:doc "Run offline pure-core unit tests (no fleet/SSH needed)."
            :extra-paths ["test"]
		            :requires ([clojure.test :as t]
		                       [murakumo.cloud-plan-test]
		                       [murakumo.config-test]
	                       [murakumo.dash-state-test]
                       [murakumo.deploy-plan-test]
	                       [murakumo.fleet-inventory-test]
	                       [murakumo.identity-test]
	                       [murakumo.kekkai-gate-test]
	                       [murakumo.overlay-crypto-test]
	                       [murakumo.overlay-dial-test]
	                       [murakumo.overlay-driver-test]
	                       [murakumo.overlay-forward-test]
	                       [murakumo.overlay-keyring-test]
	                       [murakumo.overlay-peer-test]
	                       [murakumo.overlay-relay-test]
	                       [murakumo.overlay-runtime-test]
	                       [murakumo.overlay-service-test]
	                       [murakumo.overlay-stream-test]
	                       [murakumo.overlay-transport-test]
	                       [murakumo.overlay-adapter-test]
	                       [murakumo.persist-test]
	                       [murakumo.provision-plan-test]
	                       [murakumo.report-test]
	                       [murakumo.reconcile-test]
	                       [murakumo.smoke-test]
	                       [murakumo.tunnel-test]
	                       [murakumo.infer-test]
	                       [murakumo.infer-credits-test]
	                       [murakumo.infer-schedule-test])
		            :task (let [{:keys [fail error]} (t/run-tests 'murakumo.cloud-plan-test
		                                                          'murakumo.config-test
	                                                          'murakumo.dash-state-test
                                                          'murakumo.deploy-plan-test
	                                                          'murakumo.fleet-inventory-test
	                                                          'murakumo.identity-test
	                                                          'murakumo.kekkai-gate-test
	                                                          'murakumo.overlay-crypto-test
	                                                          'murakumo.overlay-dial-test
	                                                          'murakumo.overlay-driver-test
	                                                          'murakumo.overlay-forward-test
	                                                          'murakumo.overlay-keyring-test
	                                                          'murakumo.overlay-peer-test
	                                                          'murakumo.overlay-relay-test
	                                                          'murakumo.overlay-runtime-test
	                                                          'murakumo.overlay-service-test
	                                                          'murakumo.overlay-stream-test
	                                                          'murakumo.overlay-transport-test
	                                                          'murakumo.overlay-adapter-test
	                                                          'murakumo.persist-test
	                                                          'murakumo.provision-plan-test
	                                                          'murakumo.report-test
	                                                          'murakumo.reconcile-test
	                                                          'murakumo.smoke-test
	                                                          'murakumo.tunnel-test
	                                                          'murakumo.infer-test
	                                                          'murakumo.infer-credits-test
	                                                          'murakumo.infer-schedule-test)]
                    (System/exit (if (pos? (+ (or fail 0) (or error 0))) 1 0)))}}}
