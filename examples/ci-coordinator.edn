{:ci.coordinator/version 1
 :ci.coordinator/store-root "/var/lib/murakumo/ci-broker"
 :ci.coordinator/artifact-root "/var/lib/murakumo/artifacts"
 :ci.coordinator/artifact-transfer-temp "/var/lib/murakumo/artifact-transfers"
 :ci.coordinator/pipeline-digest "replace-with-validated-pipeline-cid"
 :ci.coordinator/rid "replace-with-kotoba-rid"
 :ci.coordinator/replicas 2
 :ci.coordinator/threshold 2
 :ci.coordinator/runner-signers
 #{"did:key:replace-with-runner-a" "did:key:replace-with-runner-b"}
 :ci.coordinator/github-secret-env "MURAKUMO_GITHUB_WEBHOOK_SECRET"
 :ci.coordinator/github-status-token-env "MURAKUMO_GITHUB_STATUS_TOKEN"
 :ci.coordinator/public-base-url "https://murakumo.cloud"
 :ci.coordinator/finalizer-interval-ms 5000
 :ci.coordinator/deployments {}
 :ci.coordinator/http-port 8791
 :ci.coordinator/lease-ttl-ms 60000
 :ci.coordinator/radicle-signers
 {"rad:replace-with-rid" #{"did:key:replace-with-authorized-signer"}}
 :ci.coordinator/overlay-request
 {:type "murakumo.overlay.adapter-request"
  :version 1
  :transport :quic
  :session {:overlay "production" :node "ci-coordinator"}
  :connect {:host "0.0.0.0" :port 4443}}}
