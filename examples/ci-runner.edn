{:ci.runner/version 1
 :ci.runner/rid "replace-with-kotoba-rid"
 :ci.runner/seed-env "MURAKUMO_CI_RUNNER_SEED"
 :ci.runner/environment-digest "replace-with-pinned-runner-environment-cid"
 :ci.runner/capabilities #{:linux :oci :clojure}
 :ci.runner/source-remotes
 {"kotoba-lang/kotobase" "https://radicle.example.invalid/kotoba-lang/kotobase.git"}
 :ci.runner/broker-request
 {:type "murakumo.overlay.adapter-request"
  :version 1
  :transport :quic
  :session {:overlay "production" :node "replace-with-runner-node"}
  :connect {:host "replace-with-coordinator-overlay-address" :port 4443}}
 :ci.runner/paths
 {:workspace-root "/var/lib/murakumo/ci-workspaces"
  :artifact-root "/var/lib/murakumo/artifacts"}
 :ci.runner/runtime "podman"
 :ci.runner/release-manifest-path "kotoba.app.edn"
 :ci.runner/heartbeat-ms 20000
 :ci.runner/poll-ms 5000}
