{:cd.node/version 1
 :cd.node/node-id "replace-with-fleet-node-name"
 :cd.node/rid "replace-with-kotoba-rid"
 :cd.node/issuers #{"did:key:replace-with-authorized-deploy-issuer"}
 :cd.node/overlay-request
 {:type "murakumo.overlay.adapter-request"
  :version 1
  :transport :quic
  :session {:overlay "production" :node "replace-with-fleet-node-name"}
  :connect {:host "0.0.0.0" :port 4433}}
 :cd.node/paths
 {:artifact-root "/var/lib/murakumo/artifacts"
  :transfer-temp "/var/lib/murakumo/transfers"
  :releases-root "/var/lib/murakumo/releases"
  :active-state "/var/lib/murakumo/active.edn"}
 :cd.node/kotoba
 {:binary "/opt/murakumo/bin/kotoba"
  :token-env "MURAKUMO_KOTOBA_TOKEN"
  :url "http://127.0.0.1:8077"
  :wit-dir "/opt/murakumo/wit"
  :health-url "http://127.0.0.1:8077/health"
  :timeout-ms 60000}
 :cd.node/max-object-bytes 536870912}
