{"kotoba-lang/kotobase"
 {:environment "production"
  :deploy-refs #{"refs/heads/main"}
  :targets ["kotoba-canary" "kotoba-node-b"]
  :batch-size 1
  :nodes
  {"kotoba-canary" {:host "canary.murakumo.internal" :port 4433}
   "kotoba-node-b" {:host "node-b.murakumo.internal" :port 4433}}
  :previous-artifact-cid "bafyreplacewithbootstrapreleasebundlecid"
  :previous-revision "replace-with-bootstrap-revision"
  :issuer-seed-env "MURAKUMO_CD_ISSUER_SEED"
  :capability-ttl-seconds 900
  :session {:overlay "production" :node "ci-coordinator"}}}
