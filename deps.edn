{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "1.12.0"}
        tech.kwik/kwik {:mvn/version "0.10.10"}
        org.bouncycastle/bcpkix-jdk18on {:mvn/version "1.78.1"}}
 :aliases
 {:quic-driver {:main-opts ["-m" "murakumo.overlay.quic-driver"]}
  :quic-cert {:main-opts ["-m" "murakumo.overlay.cert"]}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
