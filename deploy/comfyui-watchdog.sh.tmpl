#!/bin/sh
# comfyui-watchdog.sh — cron-driven self-heal for a fleet node's ComfyUI.
#
# Why cron and not com.murakumo.comfyui.plist.tmpl's LaunchAgent: verified
# live 2026-07-13 on `benjamin` that these fleet nodes do NOT reliably have
# an active `gui/<uid>` launchd domain (`who` showed no console session,
# `launchctl print gui/<uid>` itself failed) — so `launchctl bootstrap
# gui/<uid> ...` fails with "125: Domain does not support specified action"
# even though the LaunchAgent plist is well-formed. The LaunchAgent template
# is still worth keeping installed for the case a node DOES get a console
# session someday, but it cannot be the primary self-heal mechanism on a
# fleet that's normally headless. cron (and the pre-existing `@reboot` line
# this supplements) has no such session dependency — it's what the original
# comfyui launch already relied on, and what actually worked live.
#
# Runs every minute (see install instructions below). If ComfyUI is already
# running, exits immediately (cheap, idempotent, safe to run alongside a
# live render). If not, `exec`s the server directly — same "no `&`, no
# `nohup`, no shell disown gymnastics" shape as the working `@reboot` line:
# this cron-forked process just BECOMES the long-running server, exactly
# like at boot, so there is nothing extra to detach from.
#
# Install per node (substitute {{VENV_PYTHON}}, {{COMFYUI_DIR}}, {{HOME}}
# into this file, e.g. via sed, then):
#   crontab -l 2>/dev/null | grep -v comfyui-watchdog.sh > /tmp/ct
#   echo "* * * * * {{HOME}}/.gftd/comfyui-watchdog.sh" >> /tmp/ct
#   crontab /tmp/ct

if pgrep -f "{{COMFYUI_DIR}}/main.py" >/dev/null 2>&1; then
  exit 0
fi

echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) comfyui not running, restarting" >> "{{HOME}}/.gftd/comfyui-watchdog.log"
exec "{{VENV_PYTHON}}" "{{COMFYUI_DIR}}/main.py" --listen 0.0.0.0 --port 8188 --disable-auto-launch >> "{{HOME}}/.gftd/comfyui.log" 2>&1
